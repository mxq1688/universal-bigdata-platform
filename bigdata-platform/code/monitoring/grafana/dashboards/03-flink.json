{
  "description": "Flink 实时计算监控: 作业状态 / Checkpoint / 吞吐量 / 反压 / TaskManager 资源",
  "editable": true,
  "panels": [
    {
      "title": "JobManager 状态",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "up{job=\"flink\"}", "legendFormat": "JM" }]
    },
    {
      "title": "运行中作业数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "green", "mode": "fixed" } } },
      "targets": [{ "expr": "flink_jobmanager_numRunningJobs", "legendFormat": "Running" }]
    },
    {
      "title": "TaskManager 数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } } },
      "targets": [{ "expr": "flink_jobmanager_numRegisteredTaskManagers", "legendFormat": "TMs" }]
    },
    {
      "title": "Slot 使用率",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] }
        }
      },
      "targets": [
        { "expr": "flink_jobmanager_taskSlotsUsed / flink_jobmanager_taskSlotsTotal", "legendFormat": "Slots" }
      ]
    },
    {
      "title": "最近 Checkpoint 耗时",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30000 }, { "color": "red", "value": 120000 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "flink_jobmanager_job_lastCheckpointDuration", "legendFormat": "Duration" }]
    },
    {
      "title": "Checkpoint 失败数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "flink_jobmanager_job_numberOfFailedCheckpoints", "legendFormat": "Failed" }]
    },
    {
      "title": "📈 Records In / Out (条/秒)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme" } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        { "expr": "sum(rate(flink_taskmanager_job_task_numRecordsIn[5m])) by (task_name)", "legendFormat": "IN: {{ task_name }}" },
        { "expr": "-sum(rate(flink_taskmanager_job_task_numRecordsOut[5m])) by (task_name)", "legendFormat": "OUT: {{ task_name }}" }
      ]
    },
    {
      "title": "📈 Checkpoint 大小趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "expr": "flink_jobmanager_job_lastCheckpointSize", "legendFormat": "Checkpoint Size" },
        { "expr": "flink_jobmanager_job_lastCheckpointFullSize", "legendFormat": "Full Size" }
      ]
    },
    {
      "title": "⚡ 反压时间 (ms/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 500 }] }
        }
      },
      "targets": [
        { "expr": "flink_taskmanager_job_task_backPressuredTimeMsPerSecond", "legendFormat": "{{ task_name }}" }
      ]
    },
    {
      "title": "🧠 TaskManager JVM 内存",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme" } } },
      "targets": [
        { "expr": "flink_taskmanager_Status_JVM_Memory_Heap_Used", "legendFormat": "Heap Used" },
        { "expr": "flink_taskmanager_Status_JVM_Memory_Heap_Max", "legendFormat": "Heap Max" },
        { "expr": "flink_taskmanager_Status_JVM_Memory_NonHeap_Used", "legendFormat": "NonHeap Used" }
      ]
    },
    {
      "title": "♻️ GC 暂停时间",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "expr": "rate(flink_taskmanager_Status_JVM_GarbageCollector_G1_Young_Generation_Time[5m])", "legendFormat": "Young GC" },
        { "expr": "rate(flink_taskmanager_Status_JVM_GarbageCollector_G1_Old_Generation_Time[5m])", "legendFormat": "Old GC" }
      ]
    },
    {
      "title": "🔁 作业重启次数",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 3 }] }
        }
      },
      "targets": [
        { "expr": "flink_jobmanager_job_numRestarts", "legendFormat": "Restarts" }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["bigdata", "flink", "realtime"],
  "templating": {
    "list": [{ "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus" }]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "Asia/Shanghai",
  "title": "⚡ Flink 实时计算监控",
  "uid": "bigdata-flink",
  "version": 1
}
