{
  "description": "ETL 链路监控: Airflow DAG 状态 / 各层数据量 / 数据新鲜度 / Agent 分析性能",
  "editable": true,
  "panels": [
    {
      "title": "🔄 Airflow DAG 执行",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        { "expr": "increase(airflow_dagrun_failed_count[24h])", "legendFormat": "失败 (24h)" },
        { "expr": "increase(airflow_dagrun_success_count[24h])", "legendFormat": "成功 (24h)" }
      ]
    },
    {
      "title": "⏱️ Scheduler 心跳",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 60 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "time() - airflow_scheduler_heartbeat", "legendFormat": "Heartbeat Age" }]
    },
    {
      "title": "📊 任务队列",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 50 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        { "expr": "airflow_pool_running_slots", "legendFormat": "Running" },
        { "expr": "airflow_pool_queued_slots", "legendFormat": "Queued" }
      ]
    },
    {
      "title": "🤖 Agent 分析量",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } } },
      "targets": [
        { "expr": "increase(agent_analysis_requests_total[24h])", "legendFormat": "请求 (24h)" }
      ]
    },
    {
      "title": "🤖 Agent P95 延迟",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 30 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(agent_analysis_duration_seconds_bucket[1h]))", "legendFormat": "P95" }]
    },
    {
      "title": "📈 DAG 任务耗时趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        { "expr": "airflow_dag_task_duration{dag_id=\"daily_warehouse_etl\"}", "legendFormat": "{{ task_id }}" }
      ]
    },
    {
      "title": "📈 DAG 运行状态分布",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 20, "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "expr": "increase(airflow_dagrun_success_count[1h])", "legendFormat": "Success" },
        { "expr": "increase(airflow_dagrun_failed_count[1h])", "legendFormat": "Failed" }
      ]
    },
    {
      "title": "🤖 Agent 分析请求量趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme" } } },
      "targets": [
        { "expr": "rate(agent_analysis_requests_total[5m])", "legendFormat": "Requests/s" },
        { "expr": "rate(agent_analysis_errors_total[5m])", "legendFormat": "Errors/s" }
      ]
    },
    {
      "title": "🤖 Agent SQL 执行次数",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "expr": "rate(agent_sql_executions_total[5m])", "legendFormat": "SQL/s" },
        { "expr": "rate(agent_chart_generated_total[5m])", "legendFormat": "Charts/s" }
      ]
    },
    {
      "title": "📊 数仓各层数据量 (Doris 查询)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "mysql", "uid": "${DS_DORIS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "barWidth": 0.6, "groupWidth": 0.7 },
      "targets": [
        {
          "rawSql": "SELECT 'DWD 订单明细' AS layer, COUNT(*) AS count FROM dwd.dwd_trade_order_detail WHERE dt = DATE_SUB(CURDATE(), INTERVAL 1 DAY) UNION ALL SELECT 'DWS 门店汇总', COUNT(*) FROM dws.dws_trade_store_1d WHERE dt = DATE_SUB(CURDATE(), INTERVAL 1 DAY) UNION ALL SELECT 'DWS 行为汇总', COUNT(*) FROM dws.dws_user_behavior_1d WHERE dt = DATE_SUB(CURDATE(), INTERVAL 1 DAY) UNION ALL SELECT 'DWS 用户价值', COUNT(*) FROM dws.dws_user_value_1d WHERE dt = DATE_SUB(CURDATE(), INTERVAL 1 DAY) UNION ALL SELECT 'ADS 经营概览', COUNT(*) FROM ads.ads_daily_overview WHERE dt = DATE_SUB(CURDATE(), INTERVAL 1 DAY)",
          "format": "table"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["bigdata", "etl", "airflow", "agent"],
  "templating": {
    "list": [
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus" },
      { "name": "DS_DORIS", "type": "datasource", "query": "mysql" }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "Asia/Shanghai",
  "title": "🔄 ETL 链路 & Agent 分析",
  "uid": "bigdata-etl-agent",
  "version": 1
}
