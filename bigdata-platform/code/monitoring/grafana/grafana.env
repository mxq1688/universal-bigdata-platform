# =================================================================
# Grafana 环境变量配置
# =================================================================

# ---------- 基础配置 ----------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=bigdata2026

# ---------- 匿名访问 (生产关闭) ----------
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer

# ---------- Server ----------
GF_SERVER_ROOT_URL=http://localhost:3000
GF_SERVER_SERVE_FROM_SUB_PATH=false

# ---------- Dashboard ----------
GF_DASHBOARDS_DEFAULT_HOME_DASHBOARD_PATH=/var/lib/grafana/dashboards/01-platform-overview.json
GF_DASHBOARDS_MIN_REFRESH_INTERVAL=10s

# ---------- Alerting ----------
GF_ALERTING_ENABLED=true
GF_UNIFIED_ALERTING_ENABLED=true

# ---------- 日志 ----------
GF_LOG_MODE=console
GF_LOG_LEVEL=info

# ---------- 插件 ----------
GF_INSTALL_PLUGINS=grafana-clock-panel,grafana-piechart-panel

# ---------- SMTP (邮件告警) ----------
GF_SMTP_ENABLED=false
GF_SMTP_HOST=smtp.company.com:587
GF_SMTP_USER=grafana@company.com
GF_SMTP_PASSWORD=your_smtp_password
GF_SMTP_FROM_ADDRESS=grafana@company.com
GF_SMTP_FROM_NAME=Grafana BigData Platform
