# ====================== LLM ======================
# 二选一，有 ANTHROPIC_API_KEY 优先用 Anthropic，否则用 OpenAI
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ANTHROPIC_API_KEY=sk-ant-xxxx
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ====================== 数据源 ======================
# 支持 mysql / postgresql / clickhouse
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=bigdata

# ====================== Web ======================
WEB_HOST=0.0.0.0
WEB_PORT=8501

# ====================== Agent ======================
MAX_SQL_EXECUTIONS=10
MAX_QUERY_ROWS=5000
CHART_OUTPUT_DIR=./output/charts
REPORT_OUTPUT_DIR=./output/reports
