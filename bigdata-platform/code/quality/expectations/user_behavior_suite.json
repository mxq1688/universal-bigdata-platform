{
  "expectation_suite_name": "user_behavior_suite",
  "expectations": [
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "user_id"},
      "meta": {"notes": "用户 ID 不能为空"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "action"},
      "meta": {"notes": "行为类型不能为空"}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "action",
        "value_set": ["view", "click", "cart", "order", "pay", "search", "favorite"]
      },
      "meta": {"notes": "行为类型必须在允许的枚举值内"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "product_id"},
      "meta": {"notes": "商品 ID 不能为空"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "timestamp"},
      "meta": {"notes": "事件时间戳不能为空"}
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {"min_value": 1},
      "meta": {"notes": "表数据量至少 1 行"}
    }
  ],
  "meta": {
    "great_expectations_version": "0.18.0",
    "description": "用户行为表数据质量规则集"
  }
}
