{
  "job": {
    "setting": {
      "speed": {
        "channel": 5,
        "byte": 104857600
      },
      "errorLimit": {
        "record": 0,
        "percentage": 0.02
      }
    },
    "content": [
      {
        "reader": {
          "name": "mysqlreader",
          "parameter": {
            "username": "${MYSQL_USER}",
            "password": "${MYSQL_PASSWORD}",
            "column": ["*"],
            "connection": [
              {
                "querySql": [
                  "SELECT order_id, user_id, store_id, total_amount, status, payment_method, city, device, create_time, update_time FROM orders WHERE DATE(create_time) = '${RUN_DATE}'"
                ],
                "jdbcUrl": [
                  "jdbc:mysql://${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DB}?useUnicode=true&characterEncoding=utf-8&useSSL=false&tinyInt1isBit=false&serverTimezone=Asia/Shanghai"
                ]
              }
            ],
            "splitPk": "order_id",
            "fetchSize": 1024
          }
        },
        "writer": {
          "name": "hdfswriter",
          "parameter": {
            "defaultFS": "${HDFS_URL}",
            "path": "/user/hive/warehouse/ods_mysql.db/ods_mysql_orders/dt=${RUN_DATE}",
            "fileName": "orders",
            "column": [
              {"index": 0, "name": "order_id", "type": "string"},
              {"index": 1, "name": "user_id", "type": "string"},
              {"index": 2, "name": "store_id", "type": "string"},
              {"index": 3, "name": "total_amount", "type": "double"},
              {"index": 4, "name": "status", "type": "string"},
              {"index": 5, "name": "payment_method", "type": "string"},
              {"index": 6, "name": "city", "type": "string"},
              {"index": 7, "name": "device", "type": "string"},
              {"index": 8, "name": "create_time", "type": "string"},
              {"index": 9, "name": "update_time", "type": "string"}
            ],
            "writeMode": "append",
            "fieldDelimiter": "\t",
            "compress": "gzip",
            "encoding": "UTF-8",
            "fileType": "text"
          }
        }
      }
    ]
  }
}
