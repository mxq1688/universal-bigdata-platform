{
  "job": {
    "setting": {
      "speed": {
        "channel": 3,
        "byte": 104857600
      },
      "errorLimit": {
        "record": 0,
        "percentage": 0.02
      }
    },
    "content": [
      {
        "reader": {
          "name": "mysqlreader",
          "parameter": {
            "username": "${MYSQL_USER}",
            "password": "${MYSQL_PASSWORD}",
            "column": ["*"],
            "connection": [
              {
                "querySql": [
                  "SELECT product_id, product_name, category, brand, supplier_id, cost_price, market_price, status, create_time, update_time FROM products WHERE DATE(update_time) >= '${RUN_DATE}' OR DATE(create_time) >= '${RUN_DATE}'"
                ],
                "jdbcUrl": [
                  "jdbc:mysql://${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DB}?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai"
                ]
              }
            ],
            "splitPk": "product_id",
            "fetchSize": 1024
          }
        },
        "writer": {
          "name": "hdfswriter",
          "parameter": {
            "defaultFS": "${HDFS_URL}",
            "path": "/user/hive/warehouse/ods_mysql.db/ods_mysql_products/dt=${RUN_DATE}",
            "fileName": "products",
            "column": [
              {"index": 0, "name": "product_id", "type": "string"},
              {"index": 1, "name": "product_name", "type": "string"},
              {"index": 2, "name": "category", "type": "string"},
              {"index": 3, "name": "brand", "type": "string"},
              {"index": 4, "name": "supplier_id", "type": "string"},
              {"index": 5, "name": "cost_price", "type": "double"},
              {"index": 6, "name": "market_price", "type": "double"},
              {"index": 7, "name": "status", "type": "string"},
              {"index": 8, "name": "create_time", "type": "string"},
              {"index": 9, "name": "update_time", "type": "string"}
            ],
            "writeMode": "append",
            "fieldDelimiter": "\t",
            "compress": "gzip",
            "encoding": "UTF-8",
            "fileType": "text"
          }
        }
      }
    ]
  }
}
