# ========================================================
# 大数据平台 环境变量配置
# 复制本文件为 .env 并填入实际值
# ========================================================

# ====================== MySQL ======================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=bigdata_source
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here

# ====================== Kafka ======================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_BEHAVIOR_TOPIC=user_behavior
KAFKA_ORDER_TOPIC=order_events

# ====================== HDFS ======================
HDFS_URL=hdfs://namenode:8020
HDFS_WEBHDFS_URL=http://namenode:9870
HDFS_USER=hadoop
HDFS_ODS_BASE=/user/hive/warehouse/ods.db

# ====================== Doris ======================
DORIS_FE_HOST=doris-fe
DORIS_HTTP_PORT=8030
DORIS_QUERY_PORT=9030
DORIS_JDBC_URL=jdbc:mysql://doris-fe:9030/bigdata
DORIS_DB=bigdata
DORIS_USER=root
DORIS_PASSWORD=

# ====================== Elasticsearch ======================
ES_HOST=localhost
ES_PORT=9200
ES_USER=elastic
ES_PASSWORD=your_es_password_here

# ====================== Redis ======================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ====================== Airflow ======================
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql://airflow:airflow@postgres:5432/airflow

# ====================== DataX ======================
DATAX_HOME=/opt/datax

# ====================== Spark ======================
SPARK_HOME=/opt/spark
SPARK_MASTER=yarn

# ====================== Flink ======================
FLINK_HOME=/opt/flink
FLINK_JOBMANAGER=flink-jobmanager:8081

# ====================== Agent Service (LLM) ======================
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Agent 数据源 (Doris)
AGENT_DB_URL=mysql+pymysql://root:@doris-fe:9030/bigdata
AGENT_DB_TYPE=doris

# Agent Web
WEB_HOST=0.0.0.0
WEB_PORT=8501

# ====================== 告警 ======================
ALERT_EMAIL=bigdata@company.com
ALERT_WEBHOOK_URL=https://hooks.example.com/webhook

# ====================== Flink 告警阈值 ======================
LARGE_ORDER_THRESHOLD=10000

# ====================== 监控 (Prometheus + Grafana) ======================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=bigdata2026
PROMETHEUS_RETENTION_DAYS=30

# ====================== 告警 Webhook ======================
# 企业微信 / 钉钉 / 飞书 Webhook URL
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
DATA_TEAM_WEBHOOK=https://hooks.example.com/data-team
INFRA_TEAM_WEBHOOK=https://hooks.example.com/infra-team
